# macOS Finder metadata
.DS_Store

# Windows Zone.Identifier files (WSL download metadata)
*:Zone.Identifier

# Environment / secrets
.env
.env.local

# Generated CircleMUD world preview data (produced by week0_explore/bin/convert-world)
/week0_explore/preview/data/world/*
!/week0_explore/preview/data/world/.keep

# play-mud skill's live session state (player/world memory) — regenerated
# every playthrough, not meaningful to diff or review
/.claude/skills/play-mud/state/*
